{
  "name": "marking-menu",
  "version": "0.10.1",
  "description": "Marking Menu Implementation in JavaScript.",
  "license": "MIT",
  "repository": "github:QuentinRoy/Marking-Menu",
  "author": "Quentin Roy <quentin@quentinroy.fr>",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/marking-menu.mjs",
      "require": "./dist/marking-menu.js",
      "default": "./dist/marking-menu.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=24"
  },
  "packageManager": "yarn@4.17.1",
  "scripts": {
    "test": "vitest run",
    "watch-test": "vitest",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "build-demo": "yarn build && vite build --config vite.demo.config.mjs",
    "dev": "vite --config vite.demo.config.mjs",
    "watch": "vite build --watch",
    "prepare": "yarn build",
    "release": "standard-version",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "serve": "yarn preview",
    "preview": "vite preview --config vite.demo.config.mjs"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "interaction",
    "technique"
  ],
  "dependencies": {
    "raf-schd": "^4.0.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "angles": "^0.5.0",
    "csv-parse": "^7.0.0",
    "eslint": "^10.4",
    "eslint-config-xo": "^0.58.1",
    "jsdom": "^29.1.1",
    "prettier": "^3",
    "rxjs": "^7.5.5",
    "rxjs-marbles": "^7.0.1",
    "standard-version": "^9.3.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "rxjs": "^7.5.5"
  }
}
