{
  "name": "marking-menu",
  "version": "0.10.1",
  "description": "Marking Menu Implementation in JavaScript.",
  "main": "dist/marking-menu.js",
  "module": "dist/marking-menu.mjs",
  "exports": {
    ".": {
      "import": "./dist/marking-menu.mjs",
      "require": "./dist/marking-menu.js",
      "default": "./dist/marking-menu.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/QuentinRoy/Marking-Menu.git"
  },
  "scripts": {
    "test": "cross-env NODE_ENV=test jest",
    "watch-test": "yarn test --watch",
    "build": "vite build",
    "build-demo": "yarn build && vite build --config vite.demo.config.mjs",
    "dev": "yarn build && vite --config vite.demo.config.mjs",
    "watch": "vite build --watch",
    "prepare": "yarn build",
    "release": "standard-version",
    "lint": "eslint src",
    "serve": "yarn dev",
    "preview": "vite preview --config vite.demo.config.mjs",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
  "author": "Quentin Roy <quentin@quentinroy.fr>",
  "license": "MIT",
  "dependencies": {
    "raf-schd": "^4.0.3",
    "rxjs": "^7.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.17.9",
    "@babel/preset-env": "^7.16.11",
    "@commitlint/cli": "^16.2.3",
    "@commitlint/config-conventional": "^16.2.1",
    "angles": "^0.5.0",
    "babel-jest": "^27.5.1",
    "cross-env": "^7.0.3",
    "csv-parse": "^7.0.0",
    "eslint": "^8.12.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "husky": "^7.0.4",
    "jest": "^27.5.1",
    "pinst": "^3.0.0",
    "prettier": "^2.6.2",
    "rxjs-marbles": "^7.0.1",
    "standard-version": "^9.3.2",
    "vite": "^8.1.5"
  },
  "keywords": [
    "marking-menu",
