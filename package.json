{
  "name": "marking-menu",
  "version": "0.10.1",
  "description": "Marking Menu Implementation in JavaScript.",
  "main": "dist/marking-menu.js",
  "module": "dist/marking-menu.mjs",
  "exports": {
    ".": {
      "import": "./dist/marking-menu.mjs",
      "require": "./dist/marking-menu.js",
      "default": "./dist/marking-menu.js"
    }
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/QuentinRoy/Marking-Menu.git"
  },
  "scripts": {
    "test": "vitest run",
    "watch-test": "vitest",
    "coverage": "vitest run --coverage",
    "build": "vite build",
    "build-demo": "yarn build && vite build --config vite.demo.config.mjs",
    "dev": "vite --config vite.demo.config.mjs",
    "watch": "vite build --watch",
    "prepare": "yarn build",
    "release": "standard-version",
    "lint": "eslint src",
    "serve": "yarn preview",
    "preview": "vite preview --config vite.demo.config.mjs",
    "postinstall": "husky install",
    "prepack": "pinst --disable",
    "postpack": "pinst --enable"
  },
  "author": "Quentin Roy <quentin@quentinroy.fr>",
  "license": "MIT",
  "dependencies": {
    "raf-schd": "^4.0.3",
    "rxjs": "^7.5.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/eslint-plugin": "^1.6.23",
    "angles": "^0.5.0",
    "csv-parse": "^7.0.0",
    "eslint": "^10.0.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "^2.26.0",
    "husky": "^9.0.0",
    "jsdom": "^29.1.1",
    "pinst": "^3.0.0",
    "prettier": "^3.0.0",
    "rxjs-marbles": "^7.0.1",
    "standard-version": "^9.3.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  },
  "keywords": [
    "marking-menu",
    "interaction",
    "technique"
  ],
  "peerDependencies": {
    "rxjs": "^7.5.5"
  },
  "packageManager": "yarn@4.17.1"
}
