{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    ":automergeMinor",
    ":automergeBranch",
    ":semanticCommits",
    ":rebaseStalePrs",
    ":semanticCommitScopeDisabled",
    ":preserveSemverRanges"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "/eslint/",
        "/husky/",
        "/prettier/",
        "/commitlint/",
        "/standard-version/"
      ],
      "groupName": "ci"
    },
    {
      "matchPackageNames": ["/vite/"],
      "groupName": "build"
    },
    {
      "matchPackageNames": ["/vitest/", "rxjs-marbles"],
      "groupName": "test"
    }
  ]
}
